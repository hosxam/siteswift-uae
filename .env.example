# .env.example — Environment Variables

# Copy this file to .env and fill in your values.
# This is only needed if you use the Python lead scraper or set up custom tools.

# == LEAD GENERATION ==

# Google Places API Key (free tier — $200/month credit)
# Get it from: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=your_key_here

# == EMAIL (Brevo / Sendinblue) ==

# Brevo API Key for email automation
# Get it from: https://app.brevo.com/settings/keys
BREVO_API_KEY=your_brevo_key
BREVO_SENDER_EMAIL=siteswift.uae@gmail.com
BREVO_SENDER_NAME=Your Name

# == PAYMENT PROCESSING ==

# Stripe API Keys
# Get them from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# == SITE MONITORING ==

# UptimeRobot API Key (optional — for automation)
# Get from: https://uptimerobot.com/dashboard#mySettings
UPTIMEROBOT_API_KEY=your_key_here

# == ANALYTICS ==

# Google Analytics Measurement ID / G-ID
# Get from: https://analytics.google.com
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# == GENERAL ==

# Your business name
BUSINESS_NAME=SiteSwift UAE

# Your contact WhatsApp number (include country code, no +)
WHATSAPP_NUMBER=971XXXXXXXXX

# Your business email
BUSINESS_EMAIL=hello@siteswift.ae

# Default timezone
TIMEZONE=Asia/Dubai

# == OPTIONAL ==

# OpenRouter or other AI API for auto-copy generation
AI_API_KEY=your_ai_key_here
AI_MODEL=claude-sonnet-4-20250514
