# ============================================================
# SiteSwift UAE - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env
# ============================================================

# --- Business Info ---
BUSINESS_NAME=SiteSwift UAE
OUTREACH_EMAIL=hello@siteswift.ae
WHATSAPP_NUMBER=[YOUR-WHATSAPP-NUMBER]           # e.g., 971501234567 (no +)

# --- API Keys ---
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=

# Get from https://app.brevo.com > Settings > API Keys
BREVO_API_KEY=

# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# --- GitHub ---
# Personal Access Token with repo + pages permissions
GITHUB_TOKEN=
GITHUB_USERNAME=hosxam

# --- Stripe Product IDs (created after Stripe setup) ---
STRIPE_STARTER_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# --- Analytics ---
GOOGLE_ANALYTICS_ID=

# --- Webhooks ---
WEBHOOK_SECRET=
